# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kheloge_dev"

# ─────────────────────────────────────────
# Auth — JWT
# ─────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"

# ─────────────────────────────────────────
# API server
# ─────────────────────────────────────────
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:3035"

# ─────────────────────────────────────────
# Redis (Bull queues)
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=          # leave blank for local dev without auth

# ─────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─────────────────────────────────────────
# Payments — Razorpay (optional for local dev)
# ─────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ─────────────────────────────────────────
# File storage — Cloudflare R2 (optional for local dev)
# ─────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""
